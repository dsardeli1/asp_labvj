<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskManageApp</title>
    <script>
        (function () {
            var storageKey = "theme-preference";
            var theme = null;

            try {
                theme = localStorage.getItem(storageKey);
            } catch (error) {
                theme = null;
            }

            if (theme !== "light" && theme !== "dark") {
                var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
                theme = prefersDark ? "dark" : "light";
            }

            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TaskManageApp.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header class="app-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm app-navbar" aria-label="Primary">
            <div class="container-fluid">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="app-brand-mark" aria-hidden="true"></span>
                    <span class="app-brand-text">TaskManageApp</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="d-flex align-items-center ms-auto me-2 order-2 order-sm-3">
                    <button id="theme-toggle"
                            class="btn btn-sm theme-toggle-btn"
                            type="button"
                            aria-label="Toggle dark mode"
                            aria-pressed="false">
                        Dark mode
                    </button>
                </div>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between flex-sm-grow-1 order-3 order-sm-2">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Data" asp-action="Index">Data Browser</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-page">
        <main role="main" class="app-main pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer text-muted">
        <div class="container app-footer-inner">
            <p class="app-footer-copy">&copy; 2026 - TaskManageApp</p>
            <p class="app-footer-links"><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
