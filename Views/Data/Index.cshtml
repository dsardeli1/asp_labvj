@{
    ViewData["Title"] = "Data Browser";
}

<section class="data-browser-page">
<div class="dashboard-container">
    <div class="dashboard-header data-browser-hero">
        <p class="data-browser-kicker">Repository Atlas</p>
        <h1>Data Browser</h1>
        <p class="subtitle">Read-only pages for mock repository entities.</p>
    </div>

    <div class="tasks-grid">
        <a class="task-card data-nav-card" asp-controller="Data" asp-action="Tasks">
            <div class="data-nav-head">
                <span class="data-nav-badge">Core</span>
                <span class="data-nav-arrow" aria-hidden="true">-></span>
            </div>
            <h3 class="task-title">Task Items</h3>
            <p class="task-description">Browse task details, priority, due dates, and linked owner/category.</p>
            <span class="data-nav-meta">Actions, ownership, schedule</span>
        </a>
        <a class="task-card data-nav-card" asp-controller="Data" asp-action="Users">
            <div class="data-nav-head">
                <span class="data-nav-badge">People</span>
                <span class="data-nav-arrow" aria-hidden="true">-></span>
            </div>
            <h3 class="task-title">Users</h3>
            <p class="task-description">Inspect user profile data and relation counts.</p>
            <span class="data-nav-meta">Profiles, roles, ownership</span>
        </a>
        <a class="task-card data-nav-card" asp-controller="Data" asp-action="Categories">
            <div class="data-nav-head">
                <span class="data-nav-badge">Taxonomy</span>
                <span class="data-nav-arrow" aria-hidden="true">-></span>
            </div>
            <h3 class="task-title">Categories</h3>
            <p class="task-description">See category metadata, color tags, and task totals.</p>
            <span class="data-nav-meta">Labels, grouping, totals</span>
        </a>
        <a class="task-card data-nav-card" asp-controller="Data" asp-action="Comments">
            <div class="data-nav-head">
                <span class="data-nav-badge">Content</span>
                <span class="data-nav-arrow" aria-hidden="true">-></span>
            </div>
            <h3 class="task-title">Comments</h3>
            <p class="task-description">Review task comments with author and edited status.</p>
            <span class="data-nav-meta">Threaded notes, edits</span>
        </a>
        <a class="task-card data-nav-card" asp-controller="Data" asp-action="Attachments">
            <div class="data-nav-head">
                <span class="data-nav-badge">Files</span>
                <span class="data-nav-arrow" aria-hidden="true">-></span>
            </div>
            <h3 class="task-title">Task Attachments</h3>
            <p class="task-description">View placeholder attachment records for tasks.</p>
            <span class="data-nav-meta">Document links, metadata</span>
        </a>
        <a class="task-card data-nav-card" asp-controller="Data" asp-action="Histories">
            <div class="data-nav-head">
                <span class="data-nav-badge">Audit</span>
                <span class="data-nav-arrow" aria-hidden="true">-></span>
            </div>
            <h3 class="task-title">Task Histories</h3>
            <p class="task-description">Track task action log entries from mock data.</p>
            <span class="data-nav-meta">Timeline events, change trail</span>
        </a>
    </div>
</div>
</section>
