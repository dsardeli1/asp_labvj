@model TaskManageApp.Models.TaskItem

@{
    ViewData["Title"] = "Task Details";
}

<section class="data-entity-page data-entity-page-detail">
    <header class="data-entity-header">
        <h2>Task #@Model.Id</h2>
        <p class="text-muted">Read-only single-record view.</p>
    </header>

    <div class="card mb-3 data-detail-card">
        <div class="card-body data-detail-card-body">
            <h4 class="card-title">@Model.Title</h4>
            <p class="card-text">@Model.Description</p>
            <dl class="row mb-0 data-detail-grid">
                <dt class="col-sm-3 data-detail-term">Priority</dt>
                <dd class="col-sm-9 data-detail-desc">@((Priority)Model.PriorityId)</dd>
                <dt class="col-sm-3 data-detail-term">Assigned User</dt>
                <dd class="col-sm-9 data-detail-desc">@(Model.User?.FirstName) @(Model.User?.LastName) (@Model.User?.Username)</dd>
                <dt class="col-sm-3 data-detail-term">Category</dt>
                <dd class="col-sm-9 data-detail-desc">@Model.Category?.Name</dd>
                <dt class="col-sm-3 data-detail-term">Created</dt>
                <dd class="col-sm-9 data-detail-desc">@Model.CreatedDate.ToString("yyyy-MM-dd")</dd>
                <dt class="col-sm-3 data-detail-term">Due Date</dt>
                <dd class="col-sm-9 data-detail-desc">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
                <dt class="col-sm-3 data-detail-term">Status</dt>
                <dd class="col-sm-9 data-detail-desc">@(Model.IsCompleted ? "Completed" : "Open")</dd>
                <dt class="col-sm-3 data-detail-term">Comments</dt>
                <dd class="col-sm-9 data-detail-desc">@(Model.Comments?.Count ?? 0)</dd>
                <dt class="col-sm-3 data-detail-term">History Entries</dt>
                <dd class="col-sm-9 data-detail-desc">@(Model.TaskHistories?.Count ?? 0)</dd>
            </dl>
        </div>
    </div>

    <a asp-controller="Data" asp-action="Tasks" class="btn btn-outline-secondary data-entity-back-link">Back to Tasks</a>
</section>
