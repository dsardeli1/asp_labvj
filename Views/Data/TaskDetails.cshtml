@model TaskManageApp.Models.TaskItem

@{
    ViewData["Title"] = "Task Details";
}

<h2>Task #@Model.Id</h2>
<p class="text-muted">Read-only single-record view.</p>

<div class="card mb-3">
    <div class="card-body">
        <h4 class="card-title">@Model.Title</h4>
        <p class="card-text">@Model.Description</p>
        <dl class="row mb-0">
            <dt class="col-sm-3">Priority</dt>
            <dd class="col-sm-9">@((Priority)Model.PriorityId)</dd>
            <dt class="col-sm-3">Assigned User</dt>
            <dd class="col-sm-9">@(Model.User?.FirstName) @(Model.User?.LastName) (@Model.User?.Username)</dd>
            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.Name</dd>
            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@(Model.IsCompleted ? "Completed" : "Open")</dd>
            <dt class="col-sm-3">Comments</dt>
            <dd class="col-sm-9">@(Model.Comments?.Count ?? 0)</dd>
            <dt class="col-sm-3">History Entries</dt>
            <dd class="col-sm-9">@(Model.TaskHistories?.Count ?? 0)</dd>
        </dl>
    </div>
</div>

<a asp-controller="Data" asp-action="Tasks" class="btn btn-outline-secondary">Back to Tasks</a>
