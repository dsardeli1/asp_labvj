@model TaskManageApp.Models.TaskAttachment

@{
    ViewData["Title"] = "Attachment Details";
}

<h2>Attachment #@Model.Id</h2>
<p class="text-muted">Read-only single-record view.</p>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">File Name</dt>
            <dd class="col-sm-9">@Model.FileName</dd>
            <dt class="col-sm-3">File Path</dt>
            <dd class="col-sm-9">@Model.FilePath</dd>
            <dt class="col-sm-3">Task</dt>
            <dd class="col-sm-9">#@Model.TaskItemId - @Model.TaskItem?.Title</dd>
        </dl>
    </div>
</div>

<a asp-controller="Data" asp-action="Attachments" class="btn btn-outline-secondary">Back to Attachments</a>
