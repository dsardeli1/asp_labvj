@model TaskManageApp.Models.TaskAttachment

@{
    ViewData["Title"] = "Attachment Details";
}

<section class="data-entity-page data-entity-page-detail">
    <header class="data-entity-header">
        <h2>Attachment #@Model.Id</h2>
        <p class="text-muted">Read-only single-record view.</p>
    </header>

    <div class="card mb-3 data-detail-card">
        <div class="card-body data-detail-card-body">
            <dl class="row mb-0 data-detail-grid">
                <dt class="col-sm-3 data-detail-term">File Name</dt>
                <dd class="col-sm-9 data-detail-desc">@Model.FileName</dd>
                <dt class="col-sm-3 data-detail-term">File Path</dt>
                <dd class="col-sm-9 data-detail-desc">@Model.FilePath</dd>
                <dt class="col-sm-3 data-detail-term">Task</dt>
                <dd class="col-sm-9 data-detail-desc">#@Model.TaskItemId - @Model.TaskItem?.Title</dd>
            </dl>
        </div>
    </div>

    <a asp-controller="Data" asp-action="Attachments" class="btn btn-outline-secondary data-entity-back-link">Back to Attachments</a>
</section>
