@model List<TaskManageApp.Models.User>

@{
    ViewData["Title"] = "Users";
}

<section class="data-entity-page data-entity-page-list">
    <header class="data-entity-header">
        <h2>Users</h2>
        <p class="text-muted">Read-only detail view of user records.</p>
    </header>

    <div class="table-responsive data-entity-table-wrap">
        <table class="table table-striped table-hover align-middle data-entity-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Created At</th>
                    <th>Task Count</th>
                    <th>Comment Count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td><a asp-controller="Data" asp-action="UserDetails" asp-route-id="@user.Id">@user.Id</a></td>
                        <td>@user.Username</td>
                        <td>@user.Email</td>
                        <td>@user.FirstName</td>
                        <td>@user.LastName</td>
                        <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>@(user.Tasks?.Count ?? 0)</td>
                        <td>@(user.Comments?.Count ?? 0)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
