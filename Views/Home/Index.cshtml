@{
    ViewData["Title"] = "Home";
}

<section class="home-landing" aria-labelledby="home-heading">
    <p class="home-kicker">TaskManageApp</p>
    <h1 id="home-heading">Welcome back</h1>
    <p class="home-subtitle">Your workspace is ready. Jump into Tasks to view your dashboard and active items.</p>

    <div class="home-local-time" aria-live="polite">
        <p class="time-label">Local time</p>
        <p class="time-value" id="local-time-value">--:--:--</p>
        <p class="date-value" id="local-date-value">Loading date...</p>
    </div>

    <div class="home-actions">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Tasks">Open Tasks</a>
        <a class="btn btn-outline-secondary" asp-controller="Data" asp-action="Index">Open Data Browser</a>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            var timeNode = document.getElementById("local-time-value");
            var dateNode = document.getElementById("local-date-value");

            if (!timeNode || !dateNode) {
                return;
            }

            var timeFormatter = new Intl.DateTimeFormat(undefined, {
                hour: "2-digit",
                minute: "2-digit",
                second: "2-digit"
            });

            var dateFormatter = new Intl.DateTimeFormat(undefined, {
                weekday: "long",
                year: "numeric",
                month: "long",
                day: "numeric"
            });

            var updateClock = function () {
                var now = new Date();
                timeNode.textContent = timeFormatter.format(now);
                dateNode.textContent = dateFormatter.format(now);
            };

            updateClock();
            window.setInterval(updateClock, 1000);
        })();
    </script>
}
